# Credenciais do administrador
ADMIN_USER=admin
# Gerar hash: npm run hash-password -- "sua-senha-aqui"
ADMIN_PASSWORD_HASH=$2a$10$...seu.hash.bcrypt.aqui...

# Segredo para assinatura de cookies de sessao (minimo 32 caracteres)
SESSION_SECRET=altere-para-uma-string-aleatoria-longa

# Duracao da sessao em milissegundos (padrao: 1 hora)
SESSION_MAX_AGE=3600000

# Tipo de armazenamento: "local" ou "pvc" (para ARO)
STORAGE_TYPE=local

# Diretorio dos arquivos ZIP (para PVC no ARO, usar o mountPath do PVC)
# ZIP_DIR=/mnt/plugins

# Habilitar secure cookies atras de proxy HTTPS
# TRUST_PROXY=1
